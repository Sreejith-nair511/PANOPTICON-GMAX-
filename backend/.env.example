# ==========================================
# PANOPTICON Backend Environment Variables
# ==========================================
# Copy this file to .env and fill in values

# App
APP_NAME="PANOPTICON API"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://panopticon:panopticon@localhost:5432/panopticon

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - CHANGE IN PRODUCTION
SECRET_KEY=panopticon-super-secret-jwt-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/evidence

# AWS S3 (optional - for production)
# S3_BUCKET=panopticon-evidence
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AI - Gemini (optional)
# GEMINI_API_KEY=your_gemini_api_key_here

# Model paths
YOLO_MODEL_PATH=./ai/models/yolov8n.pt
REID_MODEL_PATH=./ai/models/fastreid_baseline.pth

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./storage/chroma

# Processing
DETECTION_CONFIDENCE_THRESHOLD=0.65
REID_SIMILARITY_THRESHOLD=0.78
GPU_ENABLED=false
